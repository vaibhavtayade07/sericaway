-to-r from-[#090909] to-transparent pointer-events-none z-10\"></div><div class=\"jsx-2954bff5a5b04b12 absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#090909] to-transparent pointer-events-none z-10\"></div></div></section><section class=\"section-padding bg-[#090909] relative overflow-hidden\"><div class=\"section-shape section-shape-2\" aria-hidden=\"true\"></div><div class=\"section-shape section-shape-3\" aria-hidden=\"true\"></div><div class=\"container-app relative z-10\"><div class=\"max-w-2xl mb-16 sm:mb-20\"><h2 class=\"heading-lg text-white\" style=\"cursor:default\"><style>\n        @font-face {\n          font-family: 'InterVariable';\n          src: url('https://rsms.me/inter/font-files/InterVariable.woff2?v=4.0') format('woff2-variations');\n          font-weight: 100 900;\n          font-style: normal;\n          font-display: swap;\n        }\n      </style><span aria-hidden=\"true\"><span class=\"wh-letter\" style=\"display:inline-block;white-space:pre;font-family:&quot;InterVariable&quot;, &quot;Inter&quot;, system-ui, sans-serif;font-variation-settings:&#x27;wght&#x27; 400\">T</span><span class=\"wh-letter\" style=\"display:inline-block;white-space:pre;font-family:&quot;InterVariable&quot;, &quot;Inter&quot;, system-ui, sans-serif;font-variation-settings:&#x27;wght&#x27; 400\">r</span><span class=\"wh-letter\" style=\"display:inline-block;white-space:pre;font-family:&quot;InterVariable&quot;, &quot;Inter&quot;, system-ui, sans-serif;font-variation-settings:&#x27;wght&#x27; 400\">u</span><span class=\"wh-letter\" style=\"display:inline-block;white-space:pre;font-family:&quot;InterVariable&quot;, &quot;Inter&quot;, system-ui, sans-serif;font-variation-settings:&#x27;wght&#x27; 400\">s</span><span class=\"wh-letter\" style=\"display:inline-block;white-space:pre;font-family:&quot;InterVariable&quot;, &quot;Inter&quot;, system-ui, sans-serif;font-variation-settings:&#x27;wght&#x27; 400\">t</span><span class=\"wh-letter\" style=\"display:inline-